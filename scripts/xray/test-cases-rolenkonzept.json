{
  "projectKey": "FR",
  "testPlanName": "Rollenkonzept Ustafix.app",
  "tests": [
    { "id": "U-R-01", "testLevel": "unit", "summary": "canCreateProject bei leerer Projektliste → true", "steps": "Vorbedingung: projects = []. Aktion: canCreateProject auswerten.", "expectedResult": "true" },
    { "id": "U-R-02", "testLevel": "unit", "summary": "canCreateProject nur Worker → false", "steps": "Vorbedingung: projects = [{ role: 'worker' }]. Aktion: canCreateProject auswerten.", "expectedResult": "false" },
    { "id": "U-R-03", "testLevel": "unit", "summary": "canCreateProject mit Admin → true", "steps": "Vorbedingung: projects = [{ role: 'admin' }]. Aktion: canCreateProject auswerten.", "expectedResult": "true" },
    { "id": "U-R-04", "testLevel": "unit", "summary": "canCreateProject mit Manager → true", "steps": "Vorbedingung: projects = [{ role: 'manager' }]. Aktion: canCreateProject auswerten.", "expectedResult": "true" },
    { "id": "U-R-05", "testLevel": "unit", "summary": "canCreateProject gemischt Worker+Manager → true", "steps": "Vorbedingung: projects = [{ role: 'worker' }, { role: 'manager' }]. Aktion: canCreateProject auswerten.", "expectedResult": "true" },
    { "id": "U-R-06", "testLevel": "unit", "summary": "Admin: canDeleteDefect true", "steps": "Eingabe: myRole = 'admin'.", "expectedResult": "canDeleteDefect === true" },
    { "id": "U-R-07", "testLevel": "unit", "summary": "Manager: canDeleteDefect true", "steps": "Eingabe: myRole = 'manager'.", "expectedResult": "canDeleteDefect === true" },
    { "id": "U-R-08", "testLevel": "unit", "summary": "Worker: canDeleteDefect false", "steps": "Eingabe: myRole = 'worker'.", "expectedResult": "canDeleteDefect === false" },
    { "id": "U-R-09", "testLevel": "unit", "summary": "Admin/Manager: alle Medien löschbar", "steps": "canDeleteAll = true.", "expectedResult": "canDeleteItem(anyMedia) === true" },
    { "id": "U-R-10", "testLevel": "unit", "summary": "Worker: eigenes Medium löschbar", "steps": "canDeleteAll = false, currentUserId = item.created_by.", "expectedResult": "canDeleteItem(item) === true" },
    { "id": "U-R-11", "testLevel": "unit", "summary": "Worker: fremdes Medium nicht löschbar", "steps": "canDeleteAll = false, item.created_by ≠ currentUserId.", "expectedResult": "canDeleteItem(item) === false" },
    { "id": "U-R-12", "testLevel": "unit", "summary": "Admin/Manager: isAdminOrManager true", "steps": "myRole in ['admin','manager'].", "expectedResult": "isAdminOrManager === true" },
    { "id": "U-R-13", "testLevel": "unit", "summary": "Worker: isAdminOrManager false", "steps": "myRole = 'worker'.", "expectedResult": "isAdminOrManager === false" },
    { "id": "F-R-A01", "testLevel": "function", "summary": "Admin: Dashboard Button Neues Projekt sichtbar", "steps": "Als Admin einloggen, Dashboard öffnen.", "expectedResult": "Button sichtbar" },
    { "id": "F-R-A02", "testLevel": "function", "summary": "Admin: Projekt erstellen", "steps": "Neues Projekt anlegen (Name, Adresse), speichern.", "expectedResult": "Projekt erscheint, Rolle Admin" },
    { "id": "F-R-A03", "testLevel": "function", "summary": "Admin: Einheit anlegen", "steps": "Im Projekt Einheiten → neue Einheit eingeben, speichern.", "expectedResult": "Einheit erscheint / im Mangel-Dropdown" },
    { "id": "F-R-A04", "testLevel": "function", "summary": "Admin: Nutzer hinzufügen (registriert)", "steps": "Projekt-Team → E-Mail (Manager/Worker), Rolle wählen, Hinzufügen.", "expectedResult": "Erfolg, Nutzer in Liste" },
    { "id": "F-R-A05", "testLevel": "function", "summary": "Admin: Nutzer hinzufügen (nicht registriert) → Fehler", "steps": "E-Mail nicht registrierter Nutzer eingeben, Hinzufügen.", "expectedResult": "Fehlermeldung: Nutzer existiert nicht im System" },
    { "id": "F-R-A06", "testLevel": "function", "summary": "Admin: Mangel erfassen", "steps": "FAB → Sprechen oder Foto, Einheit/Priorität, Speichern.", "expectedResult": "Mangel erscheint in Liste" },
    { "id": "F-R-A07", "testLevel": "function", "summary": "Admin: Mangel löschen", "steps": "Mangeldetail → Mangel löschen → Bestätigen.", "expectedResult": "Mangel gelöscht, Rückkehr zur Liste" },
    { "id": "F-R-A08", "testLevel": "function", "summary": "Admin: alle Medien löschen", "steps": "Mangeldetail → bei beliebigem Medium Löschen-Icon.", "expectedResult": "Medium gelöscht" },
    { "id": "F-R-A09", "testLevel": "function", "summary": "Admin: Kommentar schreiben und löschen", "steps": "Kommentar eingeben, Senden; bei eigenem/anderem Löschen.", "expectedResult": "Schreiben ok; Löschen ok (eigene + andere)" },
    { "id": "F-R-A10", "testLevel": "function", "summary": "Admin: Mitglied entfernen", "steps": "Projekt-Team → bei Manager/Worker Entfernen.", "expectedResult": "Mitglied verschwindet (nicht bei sich selbst)" },
    { "id": "F-R-M01", "testLevel": "function", "summary": "Manager: Dashboard Button Neues Projekt sichtbar", "steps": "Als Manager einloggen, Dashboard öffnen.", "expectedResult": "Button sichtbar" },
    { "id": "F-R-M02", "testLevel": "function", "summary": "Manager: Einheiten und Projekt-Team sichtbar", "steps": "Projekt öffnen.", "expectedResult": "Sektionen Einheiten und Projekt-Team sichtbar" },
    { "id": "F-R-M03", "testLevel": "function", "summary": "Manager: Einheit anlegen", "steps": "Neue Einheit anlegen.", "expectedResult": "Erfolg" },
    { "id": "F-R-M04", "testLevel": "function", "summary": "Manager: Nutzer hinzufügen", "steps": "Worker per E-Mail hinzufügen.", "expectedResult": "Erfolg" },
    { "id": "F-R-M05", "testLevel": "function", "summary": "Manager: Mangel löschen", "steps": "Mangeldetail → Mangel löschen.", "expectedResult": "Button sichtbar, Löschen möglich" },
    { "id": "F-R-M06", "testLevel": "function", "summary": "Manager: alle Medien löschen", "steps": "Bei beliebigem Medium Löschen.", "expectedResult": "Erfolg" },
    { "id": "F-R-M07", "testLevel": "function", "summary": "Manager: Kommentare löschen (eigene + andere)", "steps": "Eigenen und fremden Kommentar löschen.", "expectedResult": "Beide löschbar" },
    { "id": "F-R-W01", "testLevel": "function", "summary": "Worker: kein Button Neues Projekt", "steps": "Als Worker einloggen, Dashboard öffnen.", "expectedResult": "Button nicht sichtbar" },
    { "id": "F-R-W02", "testLevel": "function", "summary": "Worker: kein Einheiten-/Team-Bereich", "steps": "Projekt öffnen.", "expectedResult": "Einheiten und Projekt-Team nicht sichtbar" },
    { "id": "F-R-W03", "testLevel": "function", "summary": "Worker: Mangel erfassen, Einheit nur Dropdown", "steps": "FAB → Erfassen, Einheit wählen.", "expectedResult": "Nur bestehende Einheiten wählbar, kein Einheit anlegen" },
    { "id": "F-R-W04", "testLevel": "function", "summary": "Worker: Status umschalten", "steps": "Mangeldetail → Offen / In Arbeit / Erledigt.", "expectedResult": "Alle drei Wechsel möglich" },
    { "id": "F-R-W05", "testLevel": "function", "summary": "Worker: kein Mangel löschen Button", "steps": "Mangeldetail öffnen.", "expectedResult": "Button Mangel löschen nicht sichtbar" },
    { "id": "F-R-W06", "testLevel": "function", "summary": "Worker: nur eigenes Medium löschen", "steps": "Eigenes vs. fremdes Medium prüfen.", "expectedResult": "Löschen-Icon nur bei eigenem Medium" },
    { "id": "F-R-W07", "testLevel": "function", "summary": "Worker: nur eigenen Kommentar löschen", "steps": "Eigenen und fremden Kommentar prüfen.", "expectedResult": "Nur eigener löschbar" },
    { "id": "F-R-E01", "testLevel": "function", "summary": "Empty State: Warte auf Zuweisung, kein Projekt-Button", "steps": "Als neuer User (nie zu Projekt hinzugefügt) einloggen.", "expectedResult": "Text Willkommen! Warte auf die Zuweisung…, kein Button Projekt erstellen" },
    { "id": "S-R-01", "testLevel": "integration", "summary": "Realtime: Mangel-Änderung bei anderem Client sichtbar", "steps": "Zwei Clients; einer legt Mangel an oder ändert Status.", "expectedResult": "Anderer Client sieht Änderung ohne Reload" },
    { "id": "S-R-02", "testLevel": "integration", "summary": "Realtime: Kommentare bei anderem Client sichtbar", "steps": "Ein Nutzer schreibt Kommentar.", "expectedResult": "Anderer Nutzer sieht neuen Kommentar" },
    { "id": "S-R-03", "testLevel": "integration", "summary": "PWA/Upload-Queue: Mangel mit Medien speichern", "steps": "Mangel mit Foto/Voice erfassen, ggf. schlechte Verbindung.", "expectedResult": "Upload läuft durch, Mangel erscheint mit Medien" },
    { "id": "S-R-04", "testLevel": "integration", "summary": "Auth: geschützte Routen → Redirect Login", "steps": "Ohne Login /dashboard oder /project/… aufrufen.", "expectedResult": "Weiterleitung zu /login" },
    { "id": "S-R-05", "testLevel": "integration", "summary": "RLS: Worker kann Mangel nicht löschen", "steps": "Als Worker versuchen, Mangel zu löschen (API/DB).", "expectedResult": "Löschen schlägt fehl (RLS)" },
    { "id": "S-R-06", "testLevel": "integration", "summary": "RLS: Worker kann fremdes Medium nicht löschen", "steps": "Als Worker defect_media mit created_by ≠ aktueller User löschen.", "expectedResult": "Fehlschlag (RLS)" },
    { "id": "AB-R-01", "testLevel": "acceptance", "summary": "Abnahme: Rollenmodell vollständig (Checkliste)", "steps": "Gesamte Abnahme-Checkliste aus docs/TESTSTUFEN-Rollenkonzept.md durchgehen.", "expectedResult": "Alle Punkte bestanden" }
  ]
}
