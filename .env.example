# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase direct DB URL (for Drizzle: db:generate, db:push, db:migrate, db:studio)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=

# Groq (https://console.groq.com - free API key)
GROQ_API_KEY=

# DeepL (https://www.deepl.com/pro-api - free tier 500K chars/month)
DEEPL_API_KEY=

# VAPID Keys for Web Push Notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# App URL (https://ustafix.app for production, http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (https://resend.com - free 100 emails/day for invite emails)
RESEND_API_KEY=
